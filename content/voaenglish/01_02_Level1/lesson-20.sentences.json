  },
  {
    "start": 34.32,
    "end": 38.4,
    "text": "**Anna:** Your {beard|ひげ} is really big."
  },
  {
    "start": 38.4,
    "end": 40.64,
    "text": "**Pete:** You don't like it, do you?"
  },
  {
    "start": 40.64,
