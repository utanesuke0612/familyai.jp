  },
  {
    "start": 6.96,
    "end": 7.2,
    "text": "**Anna:** C."
  },
  {
    "start": 7.28,
    "end": 9.2,
    "text": "**Anna:** is a {great|素晴らしい/素晴らしな} place to work."
  },
  {
    "start": 9.2,
    "end": 11.92,
