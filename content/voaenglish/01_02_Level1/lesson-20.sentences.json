    "start": 82.62,
    "end": 83.74,
    "text": "**Pete:** Sure."
  },
  {
    "start": 83.74,
    "end": 87.18,
    "text": "**Pete:** C, O, L, D."
  },
  {
    "start": 87.18,
    "end": 89.34,
