    "text": "Anna: Wow!"
  },
  {
    "start": 159.58,
    "end": 162.86,
    "text": "Anna: Some trees have rings."
  },
  {
    "start": 162.86,
    "end": 166.38,
    "text": "Anna: They tell the trees age like this"
  },
  {
    "start": 168.06,
    "end": 173.34,
    "text": "Anna: If a tree has twelve rings, it is twelve years old."
  },
  {
    "start": 173.98,
    "end": 175.02,
    "text": "Anna: Wow."
  },
  {
    "start": 175.26,
    "end": 177.9,
    "text": "Anna: Listen and say these sounds."
  },
  {
    "start": 177.9,
    "end": 178.22,
    "text": "Anna: Twa"
