# ============================================================
# familyai.jp — 環境変数テンプレート
# 使い方: cp .env.local.example .env.local → 各値を入力
# ⚠️ .env.local は絶対に Git にコミットしないこと
# ============================================================

# ── Database（Vercel Neon）──────────────────────────────────
# Neon ダッシュボード → Connection string からコピー
DATABASE_URL=

# ── Auth（NextAuth.js v5）───────────────────────────────────
# openssl rand -base64 32 で生成した値を貼り付け
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# IP ハッシュ化ソルト（音声再生カウント重複防止用 / openssl rand -hex 32 で生成）
IP_HASH_SALT=

# Google OAuth（Google Cloud Console で取得）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── File Storage（Vercel Blob）──────────────────────────────
# Vercel Dashboard → Storage → Blob → Token からコピー
BLOB_READ_WRITE_TOKEN=

# ── Rate Limiting（Upstash Redis）───────────────────────────
# Upstash Dashboard → Database → REST API からコピー
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI APIs（OpenRouter First）──────────────────────────────
# すべての生成AI呼び出しを OpenRouter 経由に集約
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=https://familyai.jp
OPENROUTER_APP_NAME=familyai.jp

# 日本語TTS を Voicevox 直結する場合のみ設定（任意）
# VOICEVOX_API_BASE=http://127.0.0.1:50021

# ── Payment（Phase 2 以降）──────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Public（フロントエンドから参照可能）────────────────────
# NEXT_PUBLIC_ プレフィックス付きはブラウザにも公開される
NEXT_PUBLIC_API_URL=https://familyai.jp
NEXT_PUBLIC_GA_ID=
